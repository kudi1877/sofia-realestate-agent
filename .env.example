# Sofia Real Estate Agent — environment template
# Copy to .env (gitignored) and fill in real values, OR export these vars in
# your shell rc (~/.zshrc / ~/.bashrc). Shell exports take precedence over .env.

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/listings.db

# ──────────────────────────────────────────────────────────────────────────────
# Scraping (per-request delay range, seconds)
# ──────────────────────────────────────────────────────────────────────────────
SCRAPE_DELAY_MIN=1.0
SCRAPE_DELAY_MAX=3.0

# ──────────────────────────────────────────────────────────────────────────────
# Anomaly detection thresholds
# ──────────────────────────────────────────────────────────────────────────────
# Z-score threshold (negative = below average). -1.5 ≈ bottom ~7%.
ANOMALY_ZSCORE_THRESHOLD=-1.5
# Percentage threshold (e.g. 0.85 = listing priced ≤ 85% of neighborhood avg)
ANOMALY_PCT_THRESHOLD=0.85
# Minimum listings required in a (neighborhood, type, room-count) group before
# we trust its average enough to flag anomalies against it.
MIN_LISTINGS_PER_GROUP=10

# EUR ↔ BGN fixed peg
EUR_BGN_RATE=1.9558

# ──────────────────────────────────────────────────────────────────────────────
# Telegram alert delivery
# ──────────────────────────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram → it returns a token like
#    123456789:ABCdef... — paste it below.
# 2. Get your numeric Telegram user ID by messaging @userinfobot — paste below.
# 3. Send your bot any message once so it can DM you back (Telegram
#    requires this first contact).
#
# Alternatively, set both as shell exports in ~/.zshrc:
#   export TELEGRAM_BOT_TOKEN="..."
#   export TELEGRAM_CHAT_ID="..."
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────────────────────────────────────
# Dashboard auto-deploy
# ──────────────────────────────────────────────────────────────────────────────
# Path to the sofia-realestate-dashboard repo on this machine. The agent writes
# public/data.json + public/daily-digest.json there during `export-dashboard`.
# Default = sibling directory next to this repo (../sofia-realestate-dashboard).
DASHBOARD_REPO_PATH=

# Auto git commit + push the regenerated JSON files so Vercel re-deploys.
# Set to "0" to skip git ops (write files only).
DASHBOARD_AUTO_PUSH=1
